<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Admin Panel</title>
  <link rel="stylesheet" href="/styles.css" />
  <style>
    table { width: 100%; border-collapse: collapse; margin-top: 20px; }
    th, td { border: 1px solid var(--border); padding: 10px; text-align: left; }
    th { background: rgba(0,0,0,0.3); }
  </style>
</head>
<body>
  <div class="dashboard" style="max-width: 1000px;">

    <h2>Admin Panel (Access Control Fixed)</h2>
    <p>Logged in as: <strong><%= currentUser %></strong> (Admin)</p>
    <p class="message success">Access granted — you are verified as an admin.</p>

    <h3>All Users</h3>
    <table>
      <tr><th>ID</th><th>Username</th><th>Full Name</th><th>Email</th><th>Role</th></tr>
      <% users.forEach(u => { %>
        <tr>
          <td><%= u.id %></td>
          <td><%= u.username %></td>
          <td><%= u.fullName %></td>
          <td><%= u.email %></td>
          <td><%= u.role %></td>
        </tr>
      <% }); %>
    </table>
    <br>
    <a href="/dashboard"> Back to Dashboard</a>
  </div>
</body>
</html>
